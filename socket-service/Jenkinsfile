pipeline {
    agent any

    environment {
        // Define common variables
        SERVICE_NAME = 'socket-service'
        DOCKER_IMAGE_NAME = "parkitteam/${env.JOB_BASE_NAME.replace('-CI', '')}"
        DOCKER_TAG = "build-${env.BUILD_ID}"
    }

    tools {
        jdk 'jdk17'
    }

    stages {
        stage('Checkout') {
            steps {
                // 깃에서 코드 Checkout
                echo "Checking out code..."
                checkout scm
            }
        }

        stage('Grant Permissions') {
            //when { changeset "socket-service/**" }
            steps {
                // gradlew 파일 실행 권한 부여
                dir("${SERVICE_NAME}") {
                    sh 'chmod +x ./gradlew'
                }
            }
        }

        stage('Test & Build Jar') {
            //when { changeset "socket-service/**" }
            steps {
                // 폴더 이동 후 gradle test build 실행
                dir("${SERVICE_NAME}") {
                    echo "Running tests and building JAR for ${SERVICE_NAME}..."
                    sh './gradlew clean build'
                }
            }
        }

        stage('Build Docker Image') {
            //when { changeset "socket-service/**" }
            steps {
                // 폴더 이동 후 Docker image build
                dir("${SERVICE_NAME}") {
                    echo "Building Docker Image: ${DOCKER_IMAGE_NAME}:${DOCKER_TAG}"
                    sh "docker build -t ${DOCKER_IMAGE_NAME}:${DOCKER_TAG} -t ${DOCKER_IMAGE_NAME}:latest ."
                }
            }
        }

        stage('Push Docker Image') {
            when { changeset "socket-service/**" }
            steps {
                // Docker Hub에 이미지를 푸시
                echo 'Pushing Docker Image to Docker Hub registry...'
                withCredentials([usernamePassword(credentialsId: 'dockerhub-credentials', passwordVariable: 'DOCKER_PASSWORD', usernameVariable: 'DOCKER_USERNAME')]) {
                    sh "echo \$DOCKER_PASSWORD | docker login -u \$DOCKER_USERNAME --password-stdin"
                    sh "docker push ${DOCKER_IMAGE_NAME}:${DOCKER_TAG}"
                    sh "docker push ${DOCKER_IMAGE_NAME}:latest"
                }
            }
        }
        stage('Update K8s Manifests') {
            //when { changeset "socket-service/**" }
            steps {
                echo 'Updating image tag in argocd-parkit repository...'
                withCredentials([usernamePassword(credentialsId: 'github-credentials', passwordVariable: 'GIT_PASSWORD', usernameVariable: 'GIT_USERNAME')]) {
                    sh """
                        # 남아있는 폴더 삭제
                        rm -rf argocd-parkit

                        # 새로 클론
                        git clone https://${GIT_USERNAME}:${GIT_PASSWORD}@github.com/Parkit-Team/argocd-parkit.git
                        
                        cd argocd-parkit
                        sed -i 's|image: ${DOCKER_IMAGE_NAME}:.*|image: ${DOCKER_IMAGE_NAME}:${DOCKER_TAG}|g' \
                            ${SERVICE_NAME}/deployment.yaml
                        git config user.email "jenkins@ci.com"
                        git config user.name "Jenkins CI"
                        git add ${SERVICE_NAME}/deployment.yaml
                        git commit -m "[CI] Update ${SERVICE_NAME} image to ${DOCKER_TAG}"
                        git push origin main
                    """
                }
            }
        }

        stage('Cleanup') {
            steps {
                // 필요없는 도커 이미지 삭제
                echo 'Pruning unused Docker images...'
                sh 'docker image prune -f'
            }
        }
    }

    post {
        always {
            echo "Pipeline for ${SERVICE_NAME} finished."
        }
        success {
            echo "Build Success!"
        }
        failure {
            echo "Build Failed."
        }
    }
}
